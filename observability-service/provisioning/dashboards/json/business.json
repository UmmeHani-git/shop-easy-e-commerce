{
  "uid": "shop-easy-business",
  "title": "ShopEasy — Business Overview",
  "tags": ["shop-easy", "business"],
  "timezone": "browser",
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "💰 Total Booking Amount (Revenue)",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(payment_amount_dollars_sum)", "legendFormat": "Revenue" }],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": { "mode": "fixed", "fixedColor": "green" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "value_and_name" }
    },
    {
      "id": 2,
      "title": "✅ Booked Orders",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "orders_paid_total", "legendFormat": "Booked" }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area" }
    },
    {
      "id": 3,
      "title": "⏳ Pending Orders",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 10, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "orders_created_total - orders_paid_total - orders_failed_total", "legendFormat": "Pending" }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "yellow" },
          "thresholds": { "steps": [{ "color": "yellow", "value": null }] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area" }
    },
    {
      "id": 4,
      "title": "❌ Failed Orders",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 14, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "orders_failed_total", "legendFormat": "Failed" }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 5 }] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area" }
    },
    {
      "id": 5,
      "title": "📦 Total Orders Created",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "orders_created_total", "legendFormat": "Total" }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area" }
    },
    {
      "id": 6,
      "title": "📈 Booking Amount Over Time",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 16, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(payment_amount_dollars_sum[5m]) * 300", "legendFormat": "Revenue / 5m" },
        { "expr": "rate(payment_amount_dollars_count[5m]) * 300", "legendFormat": "Transactions / 5m" }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 20, "lineWidth": 2, "spanNulls": true },
          "unit": "currencyUSD"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Transactions / 5m" }, "properties": [{ "id": "custom.axisPlacement", "value": "right" }, { "id": "unit", "value": "short" }] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "id": 7,
      "title": "🥧 Order Status Breakdown",
      "type": "piechart",
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "orders_paid_total", "legendFormat": "Booked" },
        { "expr": "orders_created_total - orders_paid_total - orders_failed_total", "legendFormat": "Pending" },
        { "expr": "orders_failed_total", "legendFormat": "Failed" }
      ],
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "Booked" }, "properties": [{ "id": "color", "value": { "fixedColor": "#10b981", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Pending" }, "properties": [{ "id": "color", "value": { "fixedColor": "#f59e0b", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Failed" }, "properties": [{ "id": "color", "value": { "fixedColor": "#ef4444", "mode": "fixed" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] } }
    },
    {
      "id": 8,
      "title": "📊 Booking Count Over Time (Booked vs Failed vs Pending)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "increase(orders_paid_total[5m])", "legendFormat": "Booked" },
        { "expr": "increase(orders_failed_total[5m])", "legendFormat": "Failed" },
        { "expr": "increase(orders_created_total[5m]) - increase(orders_paid_total[5m]) - increase(orders_failed_total[5m])", "legendFormat": "Pending" }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 30, "lineWidth": 2, "drawStyle": "bars", "stacking": { "mode": "normal" } } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Booked" }, "properties": [{ "id": "color", "value": { "fixedColor": "#10b981", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Failed" }, "properties": [{ "id": "color", "value": { "fixedColor": "#ef4444", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Pending" }, "properties": [{ "id": "color", "value": { "fixedColor": "#f59e0b", "mode": "fixed" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "last"] } }
    },
    {
      "id": 9,
      "title": "💵 Payment Amount Distribution",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "payment_amount_dollars_bucket", "legendFormat": "{{le}}", "format": "heatmap" }],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "color": { "mode": "palette-classic" } } }
    },
    {
      "id": 10,
      "title": "⚡ Order Processing Rate",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "rate(orders_created_total[5m]) * 60", "legendFormat": "Orders/min" }],
      "fieldConfig": {
        "defaults": {
          "unit": "opm",
          "min": 0, "max": 100,
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 30 }, { "color": "red", "value": 60 }] }
        }
      }
    }
  ],
  "schemaVersion": 39
}
